# ─────────────────────────────────────────────────────────────
# Go Livoo — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# Nunca commite .env.local no git (já está no .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Clerk (Autenticação) ─────────────────────────────────────
# https://dashboard.clerk.com → seu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# URLs de redirecionamento do Clerk (não alterar para produção)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/entrar
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/cadastro
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/completar-cadastro

# ── Supabase (Banco de Dados) ────────────────────────────────
# https://supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # nunca expor no browser (NEXT_PUBLIC_)

# ── Travelpayouts (Voos) ─────────────────────────────────────
# https://travelpayouts.com → Ferramentas → Token
TRAVELPAYOUTS_TOKEN=

# ── Ticketmaster (Eventos) ───────────────────────────────────
# https://developer.ticketmaster.com → My Apps → API Key
# Grátis, aprovação instantânea
TICKETMASTER_API_KEY=

# ── GetYourGuide (Experiências) ──────────────────────────────
# https://partner.getyourguide.com → Affiliate API
# Requer aprovação de parceria
GETYOURGUIDE_API_KEY=

# ── Sherpa (Documentação: visto, vacinas, passaporte) ────────
# https://developers.sherpa.com → Credentials
SHERPA_API_KEY=

# ── Stripe (Pagamento — Livoo Prep R$39) ─────────────────────
# https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_KEY=pk_test_...

# ── OpenAI (IA de Roteiro) ───────────────────────────────────
# https://platform.openai.com → API Keys
# Sem esta key, o roteiro roda em modo demo (sem custo)
OPENAI_API_KEY=sk-...

# ── URLs da aplicação ────────────────────────────────────────
# Em produção: https://livoo-two.vercel.app ou https://www.golivoo.com.br
# Em dev local: http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
