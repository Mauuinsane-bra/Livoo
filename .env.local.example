# =============================================
# Livoo — Variáveis de Ambiente
# Copie este arquivo para .env.local
# NUNCA commite .env.local no git!
# =============================================

# ── Banco de dados local (SQLite) ─────────────────────
# Não precisa instalar nada — é apenas um arquivo na pasta prisma/
DATABASE_URL="file:./prisma/livoo.db"

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ══════════════════════════════════════════════════════
# ABAIXO: APIs OPCIONAIS — deixe em branco para testar
# O site funciona sem elas (modo demonstração)
# ══════════════════════════════════════════════════════

# ── OpenAI (IA para roteiros) — opcional ──────────────
# Sem esta chave: formulário de roteiro funciona em modo demo
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── RapidAPI / Sky Scrapper (busca de voos real) ─────
# NECESSÁRIO para a busca de voos funcionar
# Plano Basic: GRATUITO (500 req/mês)
# 1. Acesse https://rapidapi.com e crie uma conta (grátis)
# 2. Busque "Sky Scrapper" (by apiheya) ou vá em:
#    https://rapidapi.com/apiheya/api/sky-scrapper
# 3. Clique em "Subscribe to Test" → escolha Basic (Free)
# 4. Sua chave aparece no header x-rapidapi-key
RAPIDAPI_KEY=

# ── Sherpa (documentação de viagem) — opcional ────────
# Sem esta chave: Livoo Prep funciona em modo demo
# Obtenha em: https://developers.sherpa.com
SHERPA_API_KEY=

# ── Resend (email de confirmação) — opcional ──────────
# Sem esta chave: formulário funciona, mas não envia email
# Obtenha em: https://resend.com (gratuito até 3.000 emails/mês)
RESEND_API_KEY=

# ── Stripe (pagamentos Livoo Prep R$39) — opcional ───
# Sem estas chaves: pagamentos não funcionam
# Obtenha em: https://stripe.com/br
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
